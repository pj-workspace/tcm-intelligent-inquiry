# 复制为 .env 后填写真实值：cp .env.example .env
#
# 热切换：修改本文件并保存后，下一轮 API 请求会重新读取配置（无需重启 uvicorn）。
# 已支持热切换：LLM_PROVIDER、各厂商 Key/模型、RERANK_*、JWT、API_KEY、MAX_UPLOAD_BYTES、
#   DATABASE_AUTO_CREATE_TABLES、INGEST_TEMP_DIR、CELERY_INGEST_ENABLED、DEFAULT_KNOWLEDGE_BASE_ID 等。
# 仍需重启 API 进程：DATABASE_URL（异步引擎在启动时创建）、仅改 Celery worker 的 broker、以及 worker 本身。
#
# 向量嵌入厂商（qwen | openai）；留空则与 LLM_PROVIDER 一致（对话用 anthropic 时仍可单独指定 qwen 嵌入）
# EMBEDDING_PROVIDER=

# ── 对话模型厂商：qwen | openai | anthropic | glm | deepseek ───────────────
LLM_PROVIDER=qwen

# 阿里云 DashScope（通义千问 + 知识库向量嵌入，推荐始终配置）
# https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 对话模型（OpenAI 兼容接口下的模型名）
QWEN_CHAT_MODEL=qwen-plus

# 向量模型（DashScope 嵌入模型名）
QWEN_EMBEDDING_MODEL=text-embedding-v3

# 检索重排序（gte-rerank，与 DASHSCOPE 同 Key；false 则仅向量召回）
RERANK_ENABLED=true
DASHSCOPE_RERANK_MODEL=gte-rerank
RERANK_CANDIDATE_MULTIPLIER=4
RERANK_MAX_CANDIDATES=40

# 兼容模式 Base URL，一般无需修改
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI（LLM_PROVIDER=openai）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Claude（LLM_PROVIDER=anthropic）
# ANTHROPIC_API_KEY=
# ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022

# 智谱 GLM（LLM_PROVIDER=glm）
# ZHIPU_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_CHAT_MODEL=glm-4

# DeepSeek（LLM_PROVIDER=deepseek）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_CHAT_MODEL=deepseek-chat

# 逗号分隔，允许的前端来源
CORS_ORIGINS=http://localhost:3000

# ── Docker 基础设施（docker compose up -d 后默认可用）──────────────────────
DATABASE_URL=postgresql+asyncpg://tcm:tcm_secret@127.0.0.1:5433/tcm
# 生产建议 false，仅通过 Alembic 管理表结构
DATABASE_AUTO_CREATE_TABLES=true
REDIS_URL=redis://127.0.0.1:6379/0
QDRANT_URL=http://127.0.0.1:6333

# 知识库上传：单文件最大字节数；异步入库临时目录（空则 backend/data/ingest_tmp）
MAX_UPLOAD_BYTES=52428800
INGEST_TEMP_DIR=

# 分块：目标长度、重叠、是否先按 Markdown ## 粗分章节
KNOWLEDGE_CHUNK_SIZE=512
KNOWLEDGE_CHUNK_OVERLAP=64
KNOWLEDGE_CHUNK_PRESPLIT_SECTIONS=true

# 异步入库：true 时用 Celery（需单独启动 worker，见项目根 docker compose profile worker）
CELERY_INGEST_ENABLED=true

# 已启用 MCP 的周期探测间隔（秒）；0 关闭（本地测试可设 0）
MCP_PROBE_INTERVAL_SECONDS=300

# 可选：Agent 工具 search_tcm_knowledge 未指定 kb_id 时优先使用此知识库
DEFAULT_KNOWLEDGE_BASE_ID=

# JWT（登录接口签发 Token；生产环境务必改为长随机串）
JWT_SECRET=dev-only-change-me-use-long-random-string
JWT_EXPIRE_MINUTES=10080

# 可选：非空时，除 Bearer 外还需请求头 X-API-Key 与本值一致（知识库 / Agent / MCP 等管理接口）
# API_KEY=

# 数据库迁移（在 backend 目录执行）：
#   alembic upgrade head
# 若表已由 init_db（create_all）建好且与当前迁移一致、但 alembic_version 为空：
#   alembic stamp head
# 若仅有初始 revision 的表、需再跑后续迁移：
#   alembic stamp fe4256aec939 && alembic upgrade head

# 复制为 .env 后填写真实值：cp .env.example .env

# 阿里云 DashScope（通义千问）API Key，与控制台一致
# https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 对话模型（OpenAI 兼容接口下的模型名）
QWEN_CHAT_MODEL=qwen-plus

# 向量模型（DashScope 嵌入模型名）
QWEN_EMBEDDING_MODEL=text-embedding-v3

# 兼容模式 Base URL，一般无需修改
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 逗号分隔，允许的前端来源
CORS_ORIGINS=http://localhost:3000

# ── Docker 基础设施（docker compose up -d 后默认可用）──────────────────────
DATABASE_URL=postgresql+asyncpg://tcm:tcm_secret@127.0.0.1:5433/tcm
REDIS_URL=redis://127.0.0.1:6379/0
QDRANT_URL=http://127.0.0.1:6333

# 可选：Agent 工具 search_tcm_knowledge 未指定 kb_id 时优先使用此知识库
DEFAULT_KNOWLEDGE_BASE_ID=

# JWT（登录接口签发 Token；生产环境务必改为长随机串）
JWT_SECRET=dev-only-change-me-use-long-random-string
JWT_EXPIRE_MINUTES=10080
